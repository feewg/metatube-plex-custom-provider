METATUBE_IMAGE_TAG=latest
METATUBE_BIND_ADDRESS=127.0.0.1
METATUBE_PUBLISHED_PORT=8080

METATUBE_AUTH_PATH=_metatube
METATUBE_AUTH_TOKEN=replace-with-a-long-random-token

METATUBE_REQUEST_TIMEOUT=60s
METATUBE_MANUAL_LIMIT=10
METATUBE_ENABLE_ACTOR_IMAGES=true
METATUBE_ENABLE_DIRECTORS=true
METATUBE_ENABLE_RATINGS=true
METATUBE_ENABLE_REAL_ACTOR_NAMES=false
METATUBE_ENABLE_BADGES=false
METATUBE_ENABLE_MOVIE_PROVIDER_FILTER=false
METATUBE_MOVIE_PROVIDER_FILTER=
METATUBE_ENABLE_TITLE_TEMPLATE=false
METATUBE_TITLE_TEMPLATE={number} {title}
METATUBE_TRANSLATION_MODE=Disabled
METATUBE_TRANSLATION_ENGINE=Baidu
METATUBE_TRANSLATION_ENGINE_PARAMETERS=
